{
  "name": "frappe-ctl",
  "version": "0.3.0",
  "description": "The missing CLI for Frappe/ERPNext. Built for humans and AI agents.",
  "type": "module",
  "bin": {
    "frappe-ctl": "./bin/frappe-ctl",
    "fctl": "./bin/frappe-ctl"
  },
  "files": [
    "bin/",
    "src/",
    "frappe-ctl.skill.md",
    "!src/**/*.test.ts",
    "!src/__fixtures__/"
  ],
  "keywords": [
    "frappe",
    "erpnext",
    "cli",
    "ai-agents",
    "mcp",
    "erp",
    "kubectl",
    "hrms",
    "frappe-cloud"
  ],
  "author": "Malhar Ujawane",
  "license": "MIT",
  "homepage": "https://ctl.malhar.tech",
  "repository": {
    "type": "git",
    "url": "https://github.com/MalharDotTech/frappe-ctl"
  },
  "engines": {
    "bun": ">=1.3.0"
  },
  "scripts": {
    "setup": "cp scripts/pre-push .git/hooks/pre-push && chmod +x .git/hooks/pre-push && echo 'pre-push hook installed'",
    "dev": "bun run src/cli.ts",
    "build": "bun build --compile --minify src/cli.ts --outfile frappe-ctl",
    "typecheck": "tsc --noEmit",
    "test": "bun test",
    "test:watch": "bun test --watch",
    "test:coverage": "bun test --coverage"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "typescript": "^5.0.0"
  }
}
